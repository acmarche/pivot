<?xml version="1.0" encoding="UTF-8"?>
<xs:schema xmlns:xs="http://www.w3.org/2001/XMLSchema" elementFormDefault="qualified"
    targetNamespace="http://pivot.tourismewallonie.be/files/xsd/pivot/3.1"
    xmlns:pim="http://pivot.tourismewallonie.be/files/xsd/pivot/3.1">
    <xs:include schemaLocation="pivot-exportfmt.xsd"/>
    <xs:include schemaLocation="pivot-query.xsd"/>
    <xs:include schemaLocation="pivot-offer.xsd"/>
    <xs:element name="export">
        <xs:complexType>
            <xs:sequence>
                <xs:element minOccurs="0" ref="pim:exportfmt"/>
                <xs:element minOccurs="0" ref="pim:Query"/>
                <xs:element minOccurs="0" ref="pim:offres"/>
            </xs:sequence>
        </xs:complexType>
    </xs:element>
</xs:schema>
